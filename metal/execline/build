#!/bin/sh -e

./configure \
    --prefix=/usr \
    --enable-shared \
    --disable-static \
    --disable-allstatic \
    --disable-static-libc \
    --libexecdir=/usr/lib

make
make DESTDIR="$1" install

# Install manual pages.
(
    cd man

    export MANPATH="$1/usr/share/man"

    make
    make install
)
