# /etc/profile
#
# System wide environment and startup programs.

# Set default path.
export PATH=/usr/local/bin:/usr/bin

# Set KISS defaults.
export KISS_PATH=/var/db/kiss/repo/core:/var/db/kiss/repo/metal:/var/db/kiss/repo/extra:/var/db/kiss/repo/xorg:/var/db/kiss/repo/community:/var/db/kiss/secret/secret
export KISS_HOOK=/etc/kiss_hook.sh

# Set default umask.
umask 022

# Load profiles from /etc/profile.d
for file in /etc/profile.d/*.sh; do
    [ -r "$file" ] && . "$file"
done

unset file
