# /etc/profile
#
# System wide environment and startup programs.

# Set default path.
export PATH=/bin

# Set the default KISS_PATH.
export KISS_PATH=/Data/Kiss/Repo/Stage0:/Data/Kiss/Repo/Metal:/Data/Kiss/Repo/core:/Data/Kiss/Repo/extra:/Data/Kiss/Repo/xorg:/Data/Kiss/Repo/community

# Set default umask.
umask 022

# Load profiles from /etc/profile.d
for file in /etc/profile.d/*.sh; do
    [ -r "$file" ] && . "$file"
done

unset file
